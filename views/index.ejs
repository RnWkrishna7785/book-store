<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Book Store | Explore</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-50 font-sans leading-normal tracking-normal">

   
    <nav class="bg-white shadow-sm border-b border-slate-200 sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16 items-center">
                <div class="flex items-center">
                    <span class="text-2xl font-black text-indigo-600 tracking-tighter">📚 BOOKSTORE</span>
                </div>
                
                <div class="flex items-center space-x-4">
                    <% if (user) { %>
                        <div class="flex items-center space-x-3 bg-indigo-50 px-3 py-1.5 rounded-full">
                            <div class="w-8 h-8 bg-indigo-600 rounded-full flex items-center justify-center text-white text-xs font-bold uppercase">
                                <%= user.charAt(0) %>
                            </div>
                            <span class="text-sm font-semibold text-indigo-900 hidden sm:block">Hi, <%= user %></span>
                        </div>
                        <a href="/add" class="bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded-lg text-sm font-bold transition-all shadow-md shadow-indigo-100">Add Book</a>
                        <a href="/logout" class="text-slate-500 hover:text-red-600 text-sm font-medium transition-colors">Logout</a>
                    <% } else { %>
                        <a href="/login" class="text-slate-600 hover:text-indigo-600 font-semibold text-sm">Login</a>
                        <a href="/signup" class="bg-indigo-600 hover:bg-indigo-700 text-white px-5 py-2 rounded-lg text-sm font-bold transition-all">Sign Up</a>
                    <% } %>
                </div>
            </div>
        </div>
    </nav>

 
    <header class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 text-center sm:text-left">
        <h1 class="text-4xl font-extrabold text-slate-900 tracking-tight">Our Library</h1>
        <p class="mt-2 text-lg text-slate-600">Explore detailed information about our books.</p>
    </header>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-20">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
            <% books.forEach(function(book) { %>
                <div class="group bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
                    
                   
                    <div class="aspect-[3/4] bg-slate-100 relative overflow-hidden">
                        <% if (book.image) { %>
                            <img src="/uploads/<%= book.image %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" alt="<%= book.title %>">
                        <% } else { %>
                            <div class="flex flex-col items-center justify-center h-full text-slate-400">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                                </svg>
                                <span class="text-xs font-medium uppercase tracking-widest">No Cover</span>
                            </div>
                        <% } %>
                        <div class="absolute top-3 right-3">
                            <span class="bg-white/90 backdrop-blur-sm text-indigo-600 text-[10px] font-black px-2 py-1 rounded-md uppercase shadow-sm"><%= book.category %></span>
                        </div>
                    </div>
                    
                    <div class="p-5">
                        <h3 class="text-lg font-bold text-slate-800 line-clamp-1"><%= book.title %></h3>
                        <p class="text-sm text-slate-500 font-medium italic mb-3">by <%= book.author %></p>
                        
                        <p class="text-slate-600 text-sm line-clamp-2 min-h-[40px] mb-4">
                            <%= book.description %>
                        </p>
                        
                        <div class="flex items-center justify-between border-t border-slate-100 pt-4">
                            <span class="text-xl font-black text-slate-900">₹<%= book.price %></span>
                            
                            <% if (user) { %>
                                <div class="flex space-x-2">
                                    <a href="/edit/<%= book._id %>" class="p-2 text-slate-400 hover:text-indigo-600 transition-colors" title="Edit Book">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                        </svg>
                                    </a>
                                    <a href="/delete/<%= book._id %>" onclick="return confirm('Delete this book?')" class="p-2 text-slate-400 hover:text-red-600 transition-colors" title="Delete Book">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                        </svg>
                                    </a>
                                </div>
                            <% } %>
                        </div>
                    </div>
                </div>
            <% }); %>
        </div>

        <% if (books.length === 0) { %>
            <div class="text-center py-20">
                <p class="text-slate-400 text-lg">No books found in the collection.</p>
            </div>
        <% } %>
    </main>

</body>
</html>